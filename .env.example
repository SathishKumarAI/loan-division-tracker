# Copy to .env to configure the backend (docker compose reads it automatically).

# AI transport for PDF analysis: claude_cli | anthropic_api | off
AI_MODE=claude_cli

# Model id used by either mode.
AI_MODEL=claude-opus-4-8

# Only needed when AI_MODE=anthropic_api.
ANTHROPIC_API_KEY=

# Frontend → backend base URL (build-time). Default suits local docker compose.
# VITE_API_URL=http://localhost:8000
